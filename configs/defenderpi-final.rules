drop tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP EXTREME MICRO BURST"; \
flags:S; ack:0; flow:to_server; \
detection_filter:track by_src, count 50, seconds 1; \
classtype:attempted-recon; sid:9000000; rev:1;)

