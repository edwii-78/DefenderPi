# 🔹 NMAP USER AGENT (HIGH CONFIDENCE)
drop http $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP NMAP USER AGENT"; \
flow:to_server,established; \
http.user_agent; content:"nmap"; nocase; fast_pattern; \
classtype:attempted-recon; sid:9000008; rev:2;)

