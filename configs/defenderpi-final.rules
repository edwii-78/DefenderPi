# RECON / NMAP (FIXED)
# =========================
#Real SYN scan detector
drop tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP SYN SCAN DETECTED"; \
flags:S; flow:to_server; \
detection_filter:track by_src, count 30, seconds 3; \
classtype:attempted-recon; sid:92; rev:1;)

# Faster scan
drop tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP FAST SYN SCAN"; \
flags:S; flow:to_server; \
detection_filter:track by_src, count 60, seconds 2; \
classtype:attempted-recon; sid:91; rev:1;)

