alert tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP POSSIBLE SYN SCAN"; \
flags:S; ack:0; flow:stateless; \
detection_filter:track by_src, count 100, seconds 10; \
classtype:attempted-recon; sid:9000002; rev:2;)

# 🔹 SLOW SCAN (ONLY ALERT)
alert tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP POSSIBLE SLOW SCAN"; \
flags:S; ack:0; flow:stateless; \
detection_filter:track by_src, count 120, seconds 60; \
