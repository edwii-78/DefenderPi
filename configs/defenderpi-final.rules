# 🔹 TRUE STEALTH SCANS (SAFE TO DROP)
drop tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP NMAP NULL SCAN"; \
flags:0; flow:stateless; \
classtype:attempted-recon; sid:9000004; rev:2;)

drop tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP NMAP FIN SCAN"; \
flags:F; flow:stateless; \
classtype:attempted-recon; sid:9000005; rev:2;)

drop tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP NMAP XMAS SCAN"; \
flags:FPU; flow:stateless; \
classtype:attempted-recon; sid:9000006; rev:2;)

# 🔹 ACK SCAN (ONLY ALERT — NOT SAFE TO DROP)
alert tcp $EXTERNAL_NET any -> $HOME_NET any \
(msg:"DP POSSIBLE ACK SCAN"; \
flags:A; ack:0; flow:stateless; \
detection_filter:track by_src, count 25, seconds 10; \
